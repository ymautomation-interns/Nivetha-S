# Rename this file to .env and fill in your real values.
# NEVER commit your real .env file to git.

# The email account you're sending FROM (e.g. Gmail address)
EMAIL_USER=youraddress@gmail.com

# For Gmail: do NOT use your normal password.
# Generate an "App Password" instead:
# https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on the Google account)
EMAIL_PASS=your_16_char_app_password

# SMTP service - "gmail" works with nodemailer's built-in service shortcut.
# If using another provider, remove EMAIL_SERVICE and use EMAIL_HOST/EMAIL_PORT instead.
EMAIL_SERVICE=gmail

# Port the backend server runs on
PORT=5000
